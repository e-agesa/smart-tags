{
  "name": "smart-car-park-tag",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/server",
    "packages/web"
  ],
  "scripts": {
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web",
    "build:server": "npm run build -w packages/server",
    "build:web": "npm run build -w packages/web",
    "lint": "npm run lint -w packages/server && npm run lint -w packages/web",
    "migrate": "npm run migrate -w packages/server"
  }
}
