<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Tags — Tag Not Available</title>
  <meta name="theme-color" content="#0f2460">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #0f2460;
      color: #f1f5f9;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      -webkit-font-smoothing: antialiased;
    }
    .card {
      background: #1a3a8f;
      border-radius: 16px;
      border: 1px solid #2451c4;
      padding: 40px 32px;
      text-align: center;
      max-width: 400px;
      width: 90%;
    }
    .icon {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: rgba(220,38,38,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      font-size: 28px;
    }
    h1 {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #dc2626;
    }
    p {
      font-size: 15px;
      color: #94a3b8;
      margin-bottom: 6px;
      line-height: 1.5;
    }
    .tag-code {
      font-family: 'SF Mono', 'Fira Code', monospace;
      color: #64748b;
      font-size: 12px;
      background: #0f2460;
      padding: 3px 10px;
      border-radius: 20px;
      display: inline-block;
      margin-top: 8px;
    }
    .cta {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 24px;
      background: #dc2626;
      color: #fff;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      transition: background 0.15s;
    }
    .cta:hover { background: #2563eb; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">&#x26A0;</div>
    <h1>Tag Not Available</h1>
    <p><%= message %></p>
    <span class="tag-code"><%= tagCode %></span>
    <br>
    <a class="cta" href="/register">Get your own Smart Tag</a>
  </div>
</body>
</html>
